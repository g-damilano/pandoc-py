Pandoc
  (Meta { unMeta = fromList
    [ ("title", MetaInlines [ Str "Native" , Space , Str "packet" ])
    , ("draft", MetaBool True)
    , ("tags", MetaList [ MetaString "alpha" , MetaString "beta" ])
    ] })
  [ Para
      [ Underline [ Str "Underline" ]
      , Space
      , SmallCaps [ Str "Small" , Space , Str "caps" ]
      , Space
      , Quoted DoubleQuote [ Str "quoted" ]
      ]
  , LineBlock
      [ [ Str "one" ]
      , []
      , [ Str "two" ]
      ]
  , Null
  ]
