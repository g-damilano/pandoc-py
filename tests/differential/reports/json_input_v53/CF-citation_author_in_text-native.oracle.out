[ Para
    [ Cite
        [ Citation
            { citationId = "doe"
            , citationPrefix = []
            , citationSuffix = [ Str "p.\160\&3" ]
            , citationMode = AuthorInText
            , citationNoteNum = 1
            , citationHash = 0
            }
        ]
        [ Str "@doe" , Space , Str "[p." , Space , Str "3]" ]
    ]
]
